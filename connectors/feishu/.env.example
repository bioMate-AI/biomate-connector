# BioMate Feishu/Lark connector — copy to .env and fill in. NEVER commit .env.

# ── Feishu / Lark app (open.feishu.cn → your custom app) ──
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
# Feishu (China): https://open.feishu.cn   |   Lark (international): https://open.larksuite.com
FEISHU_BASE=https://open.feishu.cn

# ── The BioMate backend this bot connects to ──
BIOMATE_API_URL=https://test.stage-public.biomate.ai
BIOMATE_DEEP_LINK_BASE=https://test.stage-public.biomate.ai
# Optional shared service-account key, used only when a user hasn't run `bind`.
BIOMATE_API_KEY=

# ── This bot's OWN public HTTPS URL ──
# Required for reliable magic auto-login: card buttons point at this host's
# /connect/feishu/go so a fresh one-time login token is minted at click time.
# Must be the same host Feishu posts webhooks to. Leave blank to disable /go
# (buttons then fall back to a bare deep link → user may hit the login page).
CONNECTOR_PUBLIC_URL=https://connect.yourcompany.com
# Secret used to HMAC-sign /go auto-login links. Defaults to FEISHU_APP_SECRET
# if unset; set a dedicated random value in production.
CONNECTOR_SIGNING_SECRET=

# ── Domain the bundled Caddy will auto-TLS (docker-compose) ──
# Point this DNS A record at the host; Caddy gets a Let's Encrypt cert on boot.
CONNECTOR_DOMAIN=connect.yourcompany.com
