# BioMate Slack connector — copy to .env and fill in. NEVER commit the real .env.

# ── Slack app credentials (api.slack.com/apps → your app) ────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token        # OAuth & Permissions → Bot User OAuth Token
SLACK_SIGNING_SECRET=your-signing-secret   # Basic Information → Signing Secret

# ── BioMate backend ──────────────────────────────────────────────────────────
# Slack is single-tenant: every request authenticates with this shared key.
BIOMATE_API_URL=https://app.biomate.ai
BIOMATE_API_KEY=your-biomate-service-api-key
BIOMATE_DEEP_LINK_BASE=https://app.biomate.ai   # optional; used in result links

# ── HTTPS (Caddy path only) ──────────────────────────────────────────────────
# Public DNS name pointing at this host. Required for the caddy service to fetch
# a Let's Encrypt cert. Omit if you expose via ngrok instead (see DEPLOY.md).
CONNECTOR_DOMAIN=slack-bot.example.com
