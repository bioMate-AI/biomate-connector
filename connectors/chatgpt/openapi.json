                  "workflow_id": {
                    "type": "string",
                    "description": "Workflow ID from search_workflow."
                  },
                  "params": {
                    "type": "object",
                    "description": "Parameter dict. Required params come from get_workflow_spec.",
                    "additionalProperties": true
                  },
                  "experiment_id": {
                    "type": "string",
                    "description": "Optional experiment to attach to."
                  },
                  "stream": {
                    "type": "boolean",
                    "description": "Emit progress notifications while running. Default false.",
                    "default": false
                  }
