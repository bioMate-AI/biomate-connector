    "/tools/run_workflow": {
      "post": {
        "operationId": "run_workflow",
        "summary": "Execute a specific BioMate workflow on BioMate cloud with explicit parameters.",
        "description": "Execute a specific BioMate workflow on BioMate cloud with explicit parameters. Returns a run_id immediately. If stream=true, also emits progress notifications until the run terminates (same events as biomate_session). Use biomate_session instead when the user gave you a natural-language goal.",
        "x-streaming": true,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "workflow_id": {
                    "type": "string",
                    "description": "Workflow ID from search_workflow."
                  },
                  "params": {
                    "type": "object",
                    "description": "Parameter dict. Required params come from get_workflow_spec.",
                    "additionalProperties": true
                  },
                  "experiment_id": {
                    "type": "string",
                    "description": "Optional experiment to attach to."
                  },
                  "stream": {
                    "type": "boolean",
                    "description": "Emit progress notifications while running. Default false.",
                    "default": false
                  }
                },
                "required": [
                  "workflow_id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tool result",
