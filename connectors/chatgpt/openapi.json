    "/tools/recall_memory": {
      "post": {
        "operationId": "recall_memory",
        "summary": "Retrieve relevant prior context for the current goal: past runs on similar inputs, validated procedures, findings tagged by the user, learned parameter preferences.",
        "description": "Retrieve relevant prior context for the current goal: past runs on similar inputs, validated procedures, findings tagged by the user, learned parameter preferences. Call before biomate_session for repeat users \u2014 it dramatically improves param auto-fill and avoids re-running work.",
        "x-streaming": false,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "What to recall \u2014 usually the user's goal."
                  },
                  "scope": {
                    "type": "string",
                    "enum": [
                      "runs",
                      "findings",
                      "procedures",
                      "all"
                    ],
                    "default": "all"
                  },
                  "limit": {
                    "type": "integer",
                    "default": 5
                  }
                },
                "required": [
                  "query"
                ]
              }
            }
          }
